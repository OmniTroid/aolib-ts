{
  "name": "aolib-ts",
  "version": "0.1.0",
  "description": "Self-contained TypeScript library for the Attorney Online protocol. Owns every packet schema, both wire formats (fantacode + JSON), encode/decode, and the typed dispatch surface.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src/**/*.ts",
    "generated/**/*.ts",
    "aolib-schemas/**/*.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "bunx --bun eslint .",
    "codegen": "bun scripts/codegen.ts"
  },
  "keywords": [
    "attorney-online",
    "ao",
    "ao1",
    "ao2",
    "websocket",
    "protocol",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/bun": "^1.3.14",
    "eslint": "^9.18.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.60.0"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  }
}
