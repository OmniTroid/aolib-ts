      "type": "string",
      "const": "PV"
    },
    "player_id": {
      "type": "number"
    },
    "_cid": {
      "type": "string",
      "const": "CID",
      "default": "CID"
    },
    "char_id": {
      "type": "number"
    }
  },
  "required": [
    "$header",
    "player_id",
    "_cid",
    "char_id"
  ],
  "additionalProperties": false
}
